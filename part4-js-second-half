  if(big) big.innerHTML = OPS_STATIONS.map(renderMetarBigCard).join('');
}

/* ── SPECI DETECTION ── */
function checkSpeci(icao, raw){
  if(!raw) return;
  const isSpeci = /^SPECI\b/i.test(raw);
  const prev = speciState[icao];
  if(isSpeci && prev !== raw){
    speciState[icao] = raw;
    triggerSpeciAlarm(icao, raw);
  } else if(!isSpeci) {
    speciState[icao] = null;
  }
}

function triggerSpeciAlarm(icao, raw){
  // Visual banner
  const banner = $('speciBanner');
  $('speciBannerText').textContent = `⚠ SPECI ${icao} — ${raw.slice(0, 100)}${raw.length>100?'…':''}`;
  banner.classList.add('active');
  // Body flash
  document.body.classList.remove('speci-alert');
  void document.body.offsetWidth;
  document.body.classList.add('speci-alert');
  // Audio (3-tone alarm)
  if(!mute){
    const ctx = getAudioCtx();
    if(ctx){
      try{
        if(ctx.state==='suspended') ctx.resume();
        const now = ctx.currentTime;
        [0, 0.4, 0.8].forEach(offset=>{
          const o = ctx.createOscillator(), g = ctx.createGain();
          o.type='square'; o.frequency.value=900;
          g.gain.value=0.06;
          o.connect(g); g.connect(ctx.destination);
          o.start(now+offset); o.stop(now+offset+0.25);
          o.frequency.setValueAtTime(900, now+offset);
          o.frequency.linearRampToValueAtTime(1400, now+offset+0.12);
          o.frequency.linearRampToValueAtTime(900, now+offset+0.24);
        });
      }catch(e){}
    }
  }
  // Toast
  const toast = document.createElement('div');
  toast.className = 'toast';
  toast.textContent = `SPECI ${icao} — check OPS tab`;
  document.body.appendChild(toast);
  setTimeout(()=>toast.remove(), 8000);
  // Refresh OPS view
  renderOps();
}

/* Hook SPECI check into renderMetar */
const _origRenderMetar = renderMetar;
window._renderMetarHooked = function(icao, raw){
  const result = _origRenderMetar(icao, raw);
  const st = metarState[icao];
  if(st && st.lastRaw) checkSpeci(icao, st.lastRaw);
  if(loadedTabs.ops && OPS_STATIONS.includes(icao)) renderOps();
  return result;
};

