/* ════════════════════════════════════════════════════
   WEATHER — KNMI Bonaire scrape (current/forecast/marine)
   ════════════════════════════════════════════════════ */

const KNMI_BONAIRE = {
  current:'https://www.knmidc.org/weather/bonaire/?Current',
  forecast:'https://www.knmidc.org/weather/bonaire/?Forecast',
  marine:'https://www.knmidc.org/weather/bonaire/?Marine'
};

function extractWxFields(text){
  if(!text) return {};
  const s = String(text).replace(/\u00A0/g,' ').replace(/\s+/g,' ');
  const out = {};
  const tryMatch = (re, label, transform) => {
    const m = s.match(re);
    if(m && m[1] != null) out[label] = transform ? transform(m[1]) : m[1].trim();
  };
  tryMatch(/Temperature[^0-9-]{0,30}(-?[0-9]+(?:\.[0-9]+)?)\s*°?C/i, 'temp_c', v => parseFloat(v));
  tryMatch(/Wind\s*Chill[^0-9-]{0,30}(-?[0-9]+(?:\.[0-9]+)?)\s*°?C/i, 'wind_chill_c', v => parseFloat(v));
  tryMatch(/Heat\s*Index[^0-9-]{0,30}(-?[0-9]+(?:\.[0-9]+)?)\s*°?C/i, 'heat_index_c', v => parseFloat(v));
  tryMatch(/Dew\s*Point[^0-9-]{0,30}(-?[0-9]+(?:\.[0-9]+)?)\s*°?C/i, 'dew_c', v => parseFloat(v));
  tryMatch(/Humidity[^0-9]{0,30}([0-9]+(?:\.[0-9]+)?)\s*%/i, 'humidity', v => parseFloat(v));
  tryMatch(/Pressure[^0-9]{0,30}([0-9]+(?:\.[0-9]+)?)\s*(?:hPa|mb)/i, 'pressure_hpa', v => parseFloat(v));
  tryMatch(/(?:Wind\s*Speed|Wind)[^0-9]{0,30}([0-9]+(?:\.[0-9]+)?)\s*(?:kt|kn|km\/h|m\/s|knots)/i, 'wind_speed', v => parseFloat(v));
  tryMatch(/Wind\s*Direction[^A-Z0-9]{0,30}([A-Z]{1,3}|[0-9]{1,3})/i, 'wind_dir');
  tryMatch(/Visibility[^0-9]{0,30}([0-9]+(?:\.[0-9]+)?)\s*(?:km|m)/i, 'visibility', v => parseFloat(v));
  tryMatch(/(?:Rain|Precipitation)[^0-9]{0,30}([0-9]+(?:\.[0-9]+)?)\s*mm/i, 'rain_mm', v => parseFloat(v));
  tryMatch(/UV(?:\s*Index)?[^0-9]{0,30}([0-9]+(?:\.[0-9]+)?)/i, 'uv', v => parseFloat(v));
  tryMatch(/Solar(?:\s*Radiation)?[^0-9]{0,30}([0-9]+(?:\.[0-9]+)?)\s*W\/m/i, 'solar', v => parseFloat(v));
  // Marine specific
  tryMatch(/(?:Wave|Sig\.?\s*Wave)\s*Height[^0-9]{0,30}([0-9]+(?:\.[0-9]+)?)\s*m/i, 'wave_m', v => parseFloat(v));
  tryMatch(/(?:Sea|Water)\s*Temp[^0-9-]{0,30}(-?[0-9]+(?:\.[0-9]+)?)\s*°?C/i, 'sea_temp_c', v => parseFloat(v));
  tryMatch(/Tide[^0-9-]{0,30}(-?[0-9]+(?:\.[0-9]+)?)/i, 'tide');
  return out;
}

function wxCard(label, value, unit, sub){
  const v = (value === null || value === undefined || value === '') ? '—' : value;
  return `<div class="wx-card">
    <div class="wx-title">${label}</div>
    <div class="wx-value">${v}${unit?'<span class="wx-unit">'+unit+'</span>':''}</div>
    ${sub?`<div class="wx-sub">${sub}</div>`:''}
  </div>`;
}

async function loadWeather(){
  const cur = $('wxCurrent'), fc = $('wxForecast'), mar = $('wxMarine');
  // Current
  try{
    const out = await fetchWithRetries(KNMI_BONAIRE.current);
    if(out.ok){
      const f = extractWxFields(out.text);
      cur.innerHTML = [
        wxCard('Temperature', f.temp_c!=null?f.temp_c.toFixed(1):'—', '°C', f.heat_index_c!=null?`Feels like ${f.heat_index_c.toFixed(1)}°C`:''),
        wxCard('Humidity', f.humidity!=null?Math.round(f.humidity):'—', '%', f.dew_c!=null?`Dew point ${f.dew_c.toFixed(1)}°C`:''),
        wxCard('Wind', f.wind_speed!=null?Math.round(f.wind_speed):'—', ' kt', f.wind_dir?`From ${f.wind_dir}`:''),
        wxCard('Pressure', f.pressure_hpa!=null?Math.round(f.pressure_hpa):'—', ' hPa', ''),
        wxCard('Visibility', f.visibility!=null?(f.visibility>=1000?(f.visibility/1000).toFixed(1):f.visibility.toFixed(1)):'—', f.visibility>=1000?' km':' m', ''),
        wxCard('Rain Today', f.rain_mm!=null?f.rain_mm.toFixed(1):'—', ' mm', ''),
        f.uv!=null ? wxCard('UV Index', f.uv.toFixed(1), '', '') : '',
        f.solar!=null ? wxCard('Solar', Math.round(f.solar), ' W/m²', '') : ''
      ].filter(Boolean).join('');
    } else {
      cur.innerHTML = `<div style="grid-column:1/-1;padding:20px;color:var(--alert);text-align:center;">Failed to load KNMI Bonaire current. <a href="${KNMI_BONAIRE.current}" target="_blank" style="color:var(--accent);">Open page</a></div>`;
    }
  }catch(e){console.error('weather current',e);}

  // Forecast
  try{
    const out = await fetchWithRetries(KNMI_BONAIRE.forecast);
    if(out.ok){
      const text = sanitize(out.text);
      // Try to extract day/temp pairs
      const re = /\b(Mon|Tue|Wed|Thu|Fri|Sat|Sun|Today|Tomorrow|Tonight)[^0-9-]{0,40}(-?[0-9]+)\s*°?\s*C/gi;
      const days = [];
      let m;
      while((m = re.exec(text)) !== null && days.length < 8){
        days.push({day:m[1], temp:parseInt(m[2],10)});
      }
      if(days.length){
        fc.innerHTML = days.map(d => `<div class="wx-fc-day"><div class="d">${d.day}</div><div class="ic">☀</div><div class="t">${d.temp}°C</div></div>`).join('');
      } else {
        fc.innerHTML = `<div style="grid-column:1/-1;padding:20px;color:var(--muted);text-align:center;">No structured forecast detected. <a href="${KNMI_BONAIRE.forecast}" target="_blank" style="color:var(--accent);">View KNMI page</a></div>`;
      }
    } else {
      fc.innerHTML = `<div style="grid-column:1/-1;padding:20px;color:var(--alert);text-align:center;">Failed to load forecast. <a href="${KNMI_BONAIRE.forecast}" target="_blank" style="color:var(--accent);">Open page</a></div>`;
    }
  }catch(e){console.error('weather forecast',e);}

  // Marine
  try{
    const out = await fetchWithRetries(KNMI_BONAIRE.marine);
    if(out.ok){
      const f = extractWxFields(out.text);
      const cards = [
        f.wave_m!=null ? wxCard('Wave Height', f.wave_m.toFixed(1), ' m', '') : '',
        f.sea_temp_c!=null ? wxCard('Sea Temp', f.sea_temp_c.toFixed(1), '°C', '') : '',
        f.wind_speed!=null ? wxCard('Marine Wind', Math.round(f.wind_speed), ' kt', f.wind_dir||'') : '',
        f.tide!=null ? wxCard('Tide', f.tide, '', '') : ''
      ].filter(Boolean);
      if(cards.length){
        mar.innerHTML = cards.join('');
      } else {
        mar.innerHTML = `<div style="grid-column:1/-1;padding:20px;color:var(--muted);text-align:center;">No marine data extracted. <a href="${KNMI_BONAIRE.marine}" target="_blank" style="color:var(--accent);">View KNMI Marine</a></div>`;
      }
    } else {
      mar.innerHTML = `<div style="grid-column:1/-1;padding:20px;color:var(--alert);text-align:center;">Failed to load marine. <a href="${KNMI_BONAIRE.marine}" target="_blank" style="color:var(--accent);">Open page</a></div>`;
    }
  }catch(e){console.error('weather marine',e);}
}

$('weather-refresh-btn')?.addEventListener('click', loadWeather);
$('ops-refresh-btn')?.addEventListener('click', ()=>{ refreshAllMetars().then(renderOps); });

